@model IReadOnlyList<Product>

@{
    ViewData["Title"] = "Order Items";
}

<section class="hero mb-4 p-4 p-md-5 rounded-4">
    <p class="text-uppercase fw-semibold mb-1">Order Service</p>
    <h1 class="display-6 fw-bold mb-2">Browse Items</h1>
    <p class="mb-0 text-secondary">Select a product to view details, pricing, stock, and category information.</p>
</section>

<div class="row g-4" id="product-grid">
    @foreach (var product in Model)
    {
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100 shadow-sm product-card" data-product-id="@product.Id" role="button" tabindex="0" aria-label="View details for @product.Name">
                <img src="@product.ImageUrl" class="card-img-top product-image" alt="@product.Name" />
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <h2 class="h5 mb-0">@product.Name</h2>
                        <span class="badge text-bg-light border">@product.Category</span>
                    </div>
                    <p class="text-secondary flex-grow-1">@product.Description</p>
                    <div class="d-flex justify-content-between align-items-center mt-3">
                        <span class="fw-semibold">@product.Price.ToString("C")</span>
                        <small class="text-secondary">Stock: @product.Stock</small>
                    </div>
                </div>
            </article>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/products.js" asp-append-version="true"></script>
}
